# --- Server ---
NODE_ENV=development
PORT=4000

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=school_platform

# --- Auth ---
# Use a long random string in production (e.g. `openssl rand -hex 64`).
JWT_ACCESS_SECRET=change-me-access-secret-please
JWT_REFRESH_SECRET=change-me-refresh-secret-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=14d

# --- CORS ---
# Comma-separated list. Use http://localhost:5173 for Vite dev server.
CORS_ORIGIN=http://localhost:5173,http://192.168.18.225:5173

# --- Rate limit ---
LOGIN_RATE_LIMIT_PER_MIN=10

# --- Mail encryption (Phase 3) ---
# Set this in production: `openssl rand -hex 32`. Dev has a hard-coded fallback.
MAIL_ENCRYPTION_KEY=

# --- Jitsi (Phase 4) ---
# Default uses the public meet.jit.si service. For self-hosted Jitsi, set to
# your domain (e.g. https://meet.your-school.test).
JITSI_BASE_URL=https://meet.jit.si
JITSI_ROOM_PREFIX=demo
