# API base URL — where the Express server is reachable from this device.
# iOS Simulator: http://localhost:4000
# Android Emulator: http://10.0.2.2:4000  (10.0.2.2 = host machine's localhost)
# Real device: http://<your-mac-ip>:4000 (same Wi-Fi)
# Production: https://api.yourschool.com
EXPO_PUBLIC_API_URL=http://localhost:4000
